# Maintainer: Carlos <cprieto.ortiz@gmail.com>
pkgname=jelly-bin
_pkgname=jelly
pkgver=0.1.0
pkgrel=1
pkgdesc="Native Jellyfin desktop client with bit-perfect audio and HDR/Dolby Vision video (Slint + libmpv)"
arch=('x86_64')
url="https://github.com/prietus/jlfine"
license=('MIT')
# Runtime libraries the prebuilt binary loads. Verify with `namcap`.
depends=('mpv' 'alsa-lib' 'dbus' 'fontconfig' 'libxkbcommon' 'libglvnd' 'wayland')
provides=('jelly')
conflicts=('jelly')
# The binary comes from the GitHub release; icon/license/desktop are
# fetched from the repo at the matching tag (so the tag must be cut
# AFTER the icon + packaging files were added). Run `updpkgsums` to
# replace the SKIP placeholders with real checksums.
source=("jelly-$pkgver::https://github.com/prietus/jlfine/releases/download/v$pkgver/jelly-linux-x86_64"
        "jelly-$pkgver.png::https://raw.githubusercontent.com/prietus/jlfine/v$pkgver/crates/jelly-ui/ui/icon.png"
        "jelly-$pkgver.desktop::https://raw.githubusercontent.com/prietus/jlfine/v$pkgver/packaging/jelly.desktop"
        "LICENSE-$pkgver::https://raw.githubusercontent.com/prietus/jlfine/v$pkgver/LICENSE")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

package() {
	install -Dm755 "jelly-$pkgver" "$pkgdir/usr/bin/jelly"
	install -Dm644 "jelly-$pkgver.png" "$pkgdir/usr/share/pixmaps/jelly.png"
	install -Dm644 "jelly-$pkgver.desktop" "$pkgdir/usr/share/applications/jelly.desktop"
	install -Dm644 "LICENSE-$pkgver" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
