// jlfine desktop client — login + library shell.
//
// One window, two screens (login / library) selected by the `screen`
// property. Backend toggles `busy` while async work is in flight and
// sets `error-message` on failure. Sign-in inputs come back to the
// Rust side via the `sign-in` callback.

import { Palette, ScrollView, VerticalBox, LineEdit, Button } from "std-widgets.slint";

export struct ViewItem {
    id: string,
    name: string,
    collection-type: string,
}

export struct Item {
    id: string,
    title: string,
    subtitle: string,
    image: image,
    has-image: bool,
    item-type: string,
    track-index: int,
    tech: string,
}

export struct AudioDeviceItem {
    id: string,
    description: string,
    bitperfect: bool,
}

export struct CastMember {
    name: string,
    character: string,
    image: image,
    has-image: bool,
}

export enum Screen { login, library, settings }

// --- design tokens -------------------------------------------------

global Theme {
    out property <color> bg-base: #0c0d10;
    out property <color> bg-panel: #14161b;
    out property <color> bg-sidebar: #0f1115;
    out property <color> stroke-faint: #1f242c;
    out property <color> text-primary: #e6e8ee;
    out property <color> text-muted: #8a92a3;
    out property <color> accent: #7c8cff;
    out property <color> accent-hover: #95a2ff;
    out property <color> danger: #e35a6a;

    out property <length> radius-card: 14px;
    out property <length> radius-pill: 28px;
}

// --- screens -------------------------------------------------------

component LoginScreen inherits Rectangle {
    in-out property <string> server-url;
    in-out property <string> username;
    in-out property <string> password;
    in property <string> error-message;
    in property <bool> busy;
    callback submit();

    background: Theme.bg-base;
    // soft radial-ish accent in the corner via overlaid rectangles
    Rectangle {
        x: -120px;
        y: -120px;
        width: 460px;
        height: 460px;
        border-radius: 230px;
        background: @linear-gradient(140deg, #7c8cff44 0%, transparent 60%);
    }
    Rectangle {
        x: parent.width - 200px;
        y: parent.height - 200px;
        width: 380px;
        height: 380px;
        border-radius: 190px;
        background: @linear-gradient(320deg, #4f3aff33 0%, transparent 65%);
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 420px;
        height: 460px;
        border-radius: Theme.radius-card;
        background: Theme.bg-panel;
        drop-shadow-color: #00000080;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 8px;

        VerticalLayout {
            padding: 32px;
            spacing: 18px;

            Text {
                text: "jlfine";
                font-size: 32px;
                font-weight: 700;
                color: Theme.text-primary;
            }
            Text {
                text: "Sign in to your Jellyfin server.";
                font-size: 14px;
                color: Theme.text-muted;
            }

            Rectangle { height: 4px; }

            Text {
                text: "Server URL";
                font-size: 11px;
                color: Theme.text-muted;
            }
            server-input := LineEdit {
                placeholder-text: "https://jellyfin.example.com";
                text <=> root.server-url;
                enabled: !root.busy;
            }

            Text {
                text: "Username";
                font-size: 11px;
                color: Theme.text-muted;
            }
            user-input := LineEdit {
                placeholder-text: "user";
                text <=> root.username;
                enabled: !root.busy;
            }

            Text {
                text: "Password";
                font-size: 11px;
                color: Theme.text-muted;
            }
            pw-input := LineEdit {
                input-type: InputType.password;
                text <=> root.password;
                enabled: !root.busy;
                accepted => { root.submit(); }
            }

            Rectangle { height: 2px; }

            sign-in-btn := TouchArea {
                height: 44px;
                enabled: !root.busy;
                clicked => { root.submit(); }

                Rectangle {
                    background: parent.has-hover && !root.busy
                        ? Theme.accent-hover
                        : Theme.accent;
                    border-radius: Theme.radius-pill;
                    animate background { duration: 150ms; easing: ease-out; }

                    Text {
                        text: root.busy ? "Signing in…" : "Sign in";
                        color: white;
                        font-size: 14px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            if root.error-message != "": Text {
                text: root.error-message;
                color: Theme.danger;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }
}

component SidebarRow inherits TouchArea {
    in property <string> label;
    in property <bool> selected;
    height: 36px;

    Rectangle {
        background: parent.selected
            ? #ffffff14
            : (parent.has-hover ? #ffffff08 : transparent);
        border-radius: 8px;
        animate background { duration: 120ms; }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            alignment: start;
            Text {
                text: root.label;
                color: Theme.text-primary;
                font-size: 13px;
                vertical-alignment: center;
            }
        }
    }
}

component Card inherits Rectangle {
    in property <Item> data;
    callback clicked();
    width: 180px;
    height: 250px;

    Rectangle {
        x: 0;
        y: 0;
        width: 180px;
        height: 180px;
        border-radius: 10px;
        clip: true;
        background: #1a1d24;
        // Placeholder gradient while the image streams in.
        if !root.data.has-image: Rectangle {
            background: @linear-gradient(135deg, #1f2330 0%, #181b22 100%);
        }
        if root.data.has-image: Image {
            source: root.data.image;
            width: 100%;
            height: 100%;
            image-fit: cover;
            opacity: 1.0;
            animate opacity { duration: 220ms; easing: ease-out; }
        }
        // Hover lift.
        states [
            hovered when ta.has-hover: {
                drop-shadow-blur: 24px;
                drop-shadow-color: #00000080;
                drop-shadow-offset-y: 8px;
            }
        ]
        animate drop-shadow-blur, drop-shadow-offset-y { duration: 180ms; easing: ease-out; }
    }

    Text {
        x: 4px;
        y: 188px;
        width: 172px;
        text: root.data.title;
        color: Theme.text-primary;
        font-size: 13px;
        font-weight: 500;
        wrap: word-wrap;
        overflow: elide;
    }
    Text {
        x: 4px;
        y: 224px;
        width: 172px;
        text: root.data.subtitle;
        color: Theme.text-muted;
        font-size: 11px;
        overflow: elide;
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: pointer;
    }
}

component GenreChip inherits Rectangle {
    in property <string> label;
    height: 22px;
    width: chip-text.preferred-width + 18px;
    border-radius: 11px;
    background: #ffffff10;

    chip-text := Text {
        text: root.label;
        color: Theme.text-primary;
        font-size: 11px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        x: 9px;
        y: 0;
        width: parent.width - 18px;
        height: parent.height;
    }
}

component CastCard inherits Rectangle {
    in property <CastMember> data;
    width: 92px;

    Rectangle {
        x: (parent.width - 80px) / 2;
        y: 0;
        width: 80px;
        height: 80px;
        border-radius: 40px;
        clip: true;
        background: #1a1d24;
        if !root.data.has-image: Rectangle {
            background: @linear-gradient(135deg, #262b38 0%, #1a1d24 100%);
            Text {
                text: "👤";
                font-size: 30px;
                color: #4a5060;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        if root.data.has-image: Image {
            source: root.data.image;
            width: 100%;
            height: 100%;
            image-fit: cover;
        }
    }
    Text {
        x: 0;
        y: 86px;
        width: 100%;
        text: root.data.name;
        color: Theme.text-primary;
        font-size: 11px;
        font-weight: 500;
        horizontal-alignment: center;
        wrap: word-wrap;
        overflow: elide;
    }
    Text {
        x: 0;
        y: 120px;
        width: 100%;
        text: root.data.character;
        color: Theme.text-muted;
        font-size: 10px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

// Action button used for Reproducir (primary) / Descargar (secondary)
// on the detail page.
component DetailButton inherits TouchArea {
    in property <string> label;
    in property <bool> primary;
    mouse-cursor: pointer;

    Rectangle {
        border-radius: 8px;
        background: root.primary
            ? (parent.has-hover ? Theme.accent-hover : Theme.accent)
            : (parent.has-hover ? #ffffff1c : #ffffff12);
        animate background { duration: 120ms; }
        Text {
            text: root.label;
            color: root.primary ? #0c0d10 : Theme.text-primary;
            font-size: 13px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Small outlined pill for external links (IMDb / TMDB).
component LinkPill inherits TouchArea {
    in property <string> label;
    mouse-cursor: pointer;
    Rectangle {
        background: parent.has-hover ? #ffffff18 : #ffffff0e;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.stroke-faint;
        animate background { duration: 120ms; }
        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: 11px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Horizontally-scrollable row of pill chips (genres / tags / media info).
component ChipRow inherits Flickable {
    in property <[string]> chips;
    viewport-width: row.preferred-width;
    viewport-height: self.height;
    row := HorizontalLayout {
        height: parent.height;
        width: self.preferred-width;
        spacing: 6px;
        for c in root.chips: GenreChip {
            label: c;
        }
    }
}

// Horizontally-scrollable cast strip.
component CastStrip inherits Flickable {
    in property <[CastMember]> cast;
    viewport-width: row.preferred-width;
    viewport-height: self.height;
    row := HorizontalLayout {
        height: parent.height;
        width: self.preferred-width;
        spacing: 12px;
        padding-right: 32px;
        for c in root.cast: CastCard {
            data: c;
        }
    }
}

component TrackRow inherits Rectangle {
    in property <int> index;
    in property <string> title;
    in property <string> duration;
    in property <string> tech;
    in property <bool> alt;
    callback clicked();
    height: 44px;
    background: ta.has-hover
        ? #ffffff10
        : (root.alt ? #ffffff04 : transparent);
    border-radius: 6px;
    animate background { duration: 100ms; }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 14px;

        // Index by default; play icon appears on hover. Both are
        // absolute-positioned inside the same 32 px cell so swapping
        // them doesn't shift the rest of the row.
        Rectangle {
            width: 32px;
            Text {
                x: 0;
                y: 0;
                width: 100%;
                height: 100%;
                text: root.index > 0 ? root.index : "";
                visible: !ta.has-hover;
                color: Theme.text-muted;
                font-size: 13px;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
            Text {
                x: 0;
                y: 0;
                width: 100%;
                height: 100%;
                text: "▶";
                visible: ta.has-hover;
                color: Theme.accent;
                font-size: 12px;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }
        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: 14px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Text {
            text: root.tech;
            visible: root.tech != "";
            color: Theme.text-muted;
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-alignment: right;
        }
        Text {
            text: root.duration;
            color: Theme.text-muted;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-alignment: right;
            width: 64px;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component LibraryScreen inherits Rectangle {
    in property <[ViewItem]> views;
    in property <string> user-name;
    in property <int> selected-index;
    in property <[Item]> items;
    in property <bool> loading;
    in property <string> view-title;
    in property <string> view-subtitle;
    in property <string> view-collection-type;
    in property <string> view-mode: "grid";
    in property <bool> can-go-back: false;
    in property <image> album-image;
    in property <bool> album-has-image: false;
    in property <string> album-artist: "";
    in property <string> album-meta: "";
    in property <[string]> album-genres: [];
    in property <string> album-overview: "";
    in property <string> album-wikipedia-url: "";
    in property <string> album-download-label: "⬇  Descargar álbum";
    in property <bool> album-download-enabled: true;
    in property <bool> album-download-active: false;
    // detail page (movies / series)
    in property <image> detail-backdrop;
    in property <bool> detail-has-backdrop: false;
    in property <string> detail-meta: "";
    in property <string> detail-tagline: "";
    in property <string> detail-overview: "";
    in property <string> detail-director: "";
    in property <string> detail-writers: "";
    in property <[string]> detail-genres: [];
    in property <[CastMember]> detail-cast: [];
    in property <string> detail-premiere: "";
    in property <string> detail-country: "";
    in property <string> detail-studios: "";
    in property <[string]> detail-tags: [];
    in property <[string]> detail-media-info: [];
    in property <string> detail-imdb-url: "";
    in property <string> detail-tmdb-url: "";
    in property <bool> detail-can-play: false;
    in property <string> detail-children-label: "";
    callback select-view(int, string, string);
    callback sign-out();
    callback activate-item(string, string);
    callback back-clicked();
    callback open-settings();
    callback open-url(string);
    callback download-album();
    callback play-detail();
    callback download-detail();

    background: Theme.bg-base;

    HorizontalLayout {
        spacing: 0;

        Rectangle {
            width: 240px;
            background: Theme.bg-sidebar;

            VerticalLayout {
                padding: 16px;
                spacing: 6px;

                Text {
                    text: "Signed in as " + root.user-name;
                    color: Theme.text-muted;
                    font-size: 11px;
                }

                Rectangle { height: 12px; }
                Text { text: "LIBRARIES"; color: Theme.text-muted; font-size: 10px; letter-spacing: 1px; }

                for v[i] in root.views: SidebarRow {
                    label: v.name;
                    selected: i == root.selected-index;
                    clicked => { root.select-view(i, v.id, v.collection-type); }
                }

                Rectangle { vertical-stretch: 1; }

                TouchArea {
                    height: 32px;
                    clicked => { root.open-settings(); }
                    Rectangle {
                        background: parent.has-hover ? #ffffff08 : transparent;
                        border-radius: 8px;
                        animate background { duration: 120ms; }
                        Text {
                            text: "⚙  Settings";
                            color: Theme.text-muted;
                            font-size: 12px;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            x: 14px;
                        }
                    }
                }

                TouchArea {
                    height: 32px;
                    clicked => { root.sign-out(); }
                    Rectangle {
                        background: parent.has-hover ? #ffffff08 : transparent;
                        border-radius: 8px;
                        animate background { duration: 120ms; }
                        Text {
                            text: "Sign out";
                            color: Theme.text-muted;
                            font-size: 12px;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            x: 14px;
                        }
                    }
                }
            }
        }

        // content area
        Rectangle {
            background: Theme.bg-base;

            // Header sits above the scrollable grid. Both share horizontal
            // padding so titles align with the leftmost card.
            VerticalLayout {
                padding-left: 0px;
                padding-right: 0px;
                padding-top: 0px;
                padding-bottom: 0px;
                spacing: 0;

                Rectangle {
                    height: 88px;
                    background: Theme.bg-base;
                    // Back affordance only appears mid-stack. Title shifts
                    // right to make room without re-laying out anything.
                    back-ta := TouchArea {
                        x: 24px;
                        y: 24px;
                        width: 36px;
                        height: 36px;
                        visible: root.can-go-back;
                        mouse-cursor: pointer;
                        clicked => { root.back-clicked(); }
                        Rectangle {
                            background: parent.has-hover ? #ffffff14 : transparent;
                            border-radius: 18px;
                            animate background { duration: 120ms; }
                            Text {
                                text: "←";
                                color: Theme.text-primary;
                                font-size: 18px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Text {
                        x: root.can-go-back ? 72px : 32px;
                        y: 28px;
                        text: root.view-title;
                        color: Theme.text-primary;
                        font-size: 26px;
                        font-weight: 600;
                        animate x { duration: 180ms; easing: ease-out; }
                    }
                    Text {
                        x: root.can-go-back ? 72px : 32px;
                        y: 60px;
                        text: root.view-subtitle;
                        color: Theme.text-muted;
                        font-size: 13px;
                        animate x { duration: 180ms; easing: ease-out; }
                    }
                    Text {
                        x: parent.width - self.width - 32px;
                        y: 32px;
                        visible: root.loading;
                        text: "Loading…";
                        color: Theme.text-muted;
                        font-size: 12px;
                    }
                }

                // Body holds both views stacked; only one is visible
                // at a time. We avoid `if` inside the surrounding layout
                // because conditional layout children don't always
                // re-react to property changes the way absolute-
                // positioned children do.
                Rectangle {
                    vertical-stretch: 1;

                    grid := Flickable {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        visible: root.view-mode == "grid";
                        property <int> cols: max(1, floor((self.width - 32px - 32px) / (180px + 20px)));
                        property <int> rows: ceil(root.items.length / max(1, self.cols));
                        viewport-width: self.width;
                        viewport-height: max(self.height, self.rows * (250px + 20px) + 32px);

                        for it[i] in root.items: Card {
                            x: 32px + mod(i, parent.cols) * (180px + 20px);
                            y: 16px + floor(i / max(1, parent.cols)) * (250px + 20px);
                            data: it;
                            clicked => {
                                root.activate-item(it.id, it.item-type);
                            }
                        }
                    }

                    tracks := Flickable {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        visible: root.view-mode == "tracklist";
                        viewport-width: self.width;
                        // Header is fixed 232px (200 cover + 16 top + 16 bottom).
                        // Overview card sits between header and tracks when
                        // there's text; otherwise we collapse the gap and
                        // tracks start right after the header.
                        property <length> header-h: 232px;
                        property <length> overview-h: root.album-overview != "" ? 156px : 0px;
                        property <length> tracks-start: self.header-h + self.overview-h;
                        viewport-height: max(self.height, root.items.length * 48px + self.tracks-start + 32px);

                        // ── Header row: cover + title/artist/meta/genres ──
                        Rectangle {
                            x: 32px;
                            y: 16px;
                            width: 200px;
                            height: 200px;
                            border-radius: 10px;
                            clip: true;
                            background: #1a1d24;
                            drop-shadow-color: #00000080;
                            drop-shadow-blur: 24px;
                            drop-shadow-offset-y: 6px;
                            if !root.album-has-image: Rectangle {
                                background: @linear-gradient(135deg, #1f2330 0%, #181b22 100%);
                            }
                            if root.album-has-image: Image {
                                source: root.album-image;
                                width: 100%;
                                height: 100%;
                                image-fit: cover;
                            }
                        }

                        // Right-of-cover column. Title is already shown in
                        // the top nav so we lead with the artist, then the
                        // meta line (year · pistas · duración), then chips.
                        Text {
                            x: 252px;
                            y: 22px;
                            width: parent.width - 252px - 32px;
                            text: root.album-artist;
                            color: Theme.text-primary;
                            font-size: 22px;
                            font-weight: 600;
                            overflow: elide;
                        }
                        Text {
                            x: 252px;
                            y: 60px;
                            width: parent.width - 252px - 32px;
                            text: root.album-meta;
                            color: Theme.text-muted;
                            font-size: 13px;
                            overflow: elide;
                        }

                        HorizontalLayout {
                            x: 252px;
                            y: 92px;
                            width: parent.width - 252px - 32px;
                            height: 22px;
                            spacing: 6px;
                            alignment: start;
                            for g in root.album-genres: GenreChip {
                                label: g;
                            }
                        }

                        // Descargar pill. Disabled while the actual
                        // download task is in flight; the label switches
                        // to "Descargando 3/12…" from Rust.
                        download-ta := TouchArea {
                            x: 252px;
                            y: 132px;
                            width: 200px;
                            height: 32px;
                            enabled: root.album-download-enabled;
                            mouse-cursor: root.album-download-enabled ? pointer : default;
                            clicked => { root.download-album(); }
                            Rectangle {
                                background: root.album-download-active
                                    ? #ffffff14
                                    : (download-ta.has-hover && root.album-download-enabled ? Theme.accent-hover : Theme.accent);
                                border-radius: 16px;
                                opacity: root.album-download-enabled || root.album-download-active ? 1.0 : 0.5;
                                animate background, opacity { duration: 140ms; }
                                Text {
                                    text: root.album-download-label;
                                    color: #0c0d10;
                                    font-size: 12px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // ── Overview / Reseña card ──────────────────────
                        if root.album-overview != "": Rectangle {
                            x: 32px;
                            y: parent.header-h + 4px;
                            width: parent.width - 64px;
                            height: 140px;
                            background: #ffffff06;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Theme.stroke-faint;

                            Text {
                                x: 18px;
                                y: 14px;
                                text: "RESEÑA";
                                color: Theme.text-muted;
                                font-size: 10px;
                                letter-spacing: 1.4px;
                                font-weight: 600;
                            }

                            // Wikipedia pill, only when we extracted a URL.
                            if root.album-wikipedia-url != "": TouchArea {
                                x: parent.width - self.width - 14px;
                                y: 10px;
                                width: 100px;
                                height: 24px;
                                mouse-cursor: pointer;
                                clicked => { root.open-url(root.album-wikipedia-url); }
                                Rectangle {
                                    background: parent.has-hover ? #ffffff18 : #ffffff10;
                                    border-radius: 12px;
                                    animate background { duration: 120ms; }
                                    Text {
                                        text: "🔗  Wikipedia";
                                        color: Theme.text-primary;
                                        font-size: 11px;
                                        font-weight: 500;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Text {
                                x: 18px;
                                y: 36px;
                                width: parent.width - 36px;
                                height: parent.height - 50px;
                                text: root.album-overview;
                                color: Theme.text-primary;
                                font-size: 13px;
                                wrap: word-wrap;
                                overflow: elide;
                            }
                        }

                        for it[i] in root.items: TrackRow {
                            x: 32px;
                            y: parent.tracks-start + i * 48px;
                            width: parent.width - 64px;
                            index: it.track-index > 0 ? it.track-index : i + 1;
                            title: it.title;
                            duration: it.subtitle;
                            tech: it.tech;
                            alt: mod(i, 2) == 1;
                            clicked => {
                                root.activate-item(it.id, it.item-type);
                            }
                        }
                    }

                    // ── Detail page: movie / series metadata ──────────
                    detail := Flickable {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        visible: root.view-mode == "detail";
                        viewport-width: self.width;

                        property <length> cw: self.width - 64px;
                        // Vertical offset chain. Each section collapses to
                        // 0 height when its content is empty so gaps don't
                        // accumulate. Mirrors the tracklist's fixed-height
                        // approach (absolute positioning re-reacts reliably
                        // where conditional layout children don't).
                        property <length> y-meta: 256px;
                        property <length> y-buttons: self.y-meta + 32px;
                        property <length> h-buttons: root.detail-can-play ? 40px : 0px;
                        property <length> y-tagline: self.y-buttons + self.h-buttons + (root.detail-can-play ? 18px : 8px);
                        property <length> h-tagline: root.detail-tagline != "" ? 24px : 0px;
                        property <length> y-overview: self.y-tagline + self.h-tagline + (root.detail-tagline != "" ? 8px : 0px);
                        property <length> h-overview: root.detail-overview != "" ? 92px : 0px;
                        property <length> y-director: self.y-overview + self.h-overview + 16px;
                        property <length> h-director: root.detail-director != "" ? 20px : 0px;
                        property <length> y-writers: self.y-director + self.h-director;
                        property <length> h-writers: root.detail-writers != "" ? 20px : 0px;
                        property <length> y-genres: self.y-writers + self.h-writers + 14px;
                        property <length> h-genres: root.detail-genres.length > 0 ? 24px : 0px;
                        property <length> y-cast-label: self.y-genres + self.h-genres + (root.detail-genres.length > 0 ? 18px : 0px);
                        property <length> h-cast-label: root.detail-cast.length > 0 ? 22px : 0px;
                        property <length> y-cast: self.y-cast-label + self.h-cast-label + 6px;
                        property <length> h-cast: root.detail-cast.length > 0 ? 148px : 0px;
                        property <length> y-facts: self.y-cast + self.h-cast + (root.detail-cast.length > 0 ? 16px : 0px);
                        property <length> h-premiere: root.detail-premiere != "" ? 20px : 0px;
                        property <length> h-country: root.detail-country != "" ? 20px : 0px;
                        property <length> h-studios: root.detail-studios != "" ? 20px : 0px;
                        property <length> y-tags: self.y-facts + self.h-premiere + self.h-country + self.h-studios + 12px;
                        property <length> h-tags: root.detail-tags.length > 0 ? 24px : 0px;
                        property <length> y-media-label: self.y-tags + self.h-tags + 18px;
                        property <length> h-media-label: root.detail-media-info.length > 0 ? 22px : 0px;
                        property <length> y-media: self.y-media-label + self.h-media-label + 6px;
                        property <length> h-media: root.detail-media-info.length > 0 ? 24px : 0px;
                        property <length> y-links: self.y-media + self.h-media + 16px;
                        property <length> h-links: (root.detail-imdb-url != "" || root.detail-tmdb-url != "") ? 30px : 0px;
                        property <length> y-children-label: self.y-links + self.h-links + 26px;
                        property <length> h-children-label: root.detail-children-label != "" ? 24px : 0px;
                        property <length> y-children: self.y-children-label + self.h-children-label + 12px;
                        property <int> grid-cols: max(1, floor(self.cw / (180px + 20px)));
                        property <int> grid-rows: ceil(root.items.length / max(1, self.grid-cols));
                        property <length> h-children: root.items.length > 0 ? self.grid-rows * (250px + 20px) : 0px;
                        viewport-height: max(self.height, self.y-children + self.h-children + 48px);

                        // Backdrop (full-bleed) + bottom fade into the page.
                        Rectangle {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: 240px;
                            clip: true;
                            background: #14161b;
                            if root.detail-has-backdrop: Image {
                                source: root.detail-backdrop;
                                width: 100%;
                                height: 100%;
                                image-fit: cover;
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                background: @linear-gradient(180deg, #0c0d1000 40%, #0c0d10cc 80%, Theme.bg-base 100%);
                            }
                        }

                        Text {
                            x: 32px;
                            y: parent.y-meta;
                            width: parent.cw;
                            text: root.detail-meta;
                            color: Theme.text-muted;
                            font-size: 13px;
                        }

                        // Reproducir / Descargar.
                        play-btn := DetailButton {
                            x: 32px;
                            y: parent.y-buttons;
                            width: 150px;
                            height: 36px;
                            visible: root.detail-can-play;
                            primary: true;
                            label: "▶  Reproducir";
                            clicked => { root.play-detail(); }
                        }
                        // Hidden until video download lands (#21) — the
                        // handler is wired but does nothing yet, so we
                        // don't ship a dead button in the beta.
                        DetailButton {
                            x: 196px;
                            y: parent.y-buttons;
                            width: 150px;
                            height: 36px;
                            visible: false;
                            primary: false;
                            label: "⬇  Descargar";
                            clicked => { root.download-detail(); }
                        }

                        Text {
                            x: 32px;
                            y: parent.y-tagline;
                            width: parent.cw;
                            visible: root.detail-tagline != "";
                            text: root.detail-tagline;
                            color: Theme.text-muted;
                            font-size: 14px;
                            font-italic: true;
                            overflow: elide;
                        }

                        Text {
                            x: 32px;
                            y: parent.y-overview;
                            width: parent.cw;
                            height: parent.h-overview;
                            visible: root.detail-overview != "";
                            text: root.detail-overview;
                            color: Theme.text-primary;
                            font-size: 14px;
                            wrap: word-wrap;
                            overflow: elide;
                        }

                        Text {
                            x: 32px;
                            y: parent.y-director;
                            width: parent.cw;
                            visible: root.detail-director != "";
                            text: root.detail-director;
                            color: Theme.text-primary;
                            font-size: 13px;
                            overflow: elide;
                        }
                        Text {
                            x: 32px;
                            y: parent.y-writers;
                            width: parent.cw;
                            visible: root.detail-writers != "";
                            text: root.detail-writers;
                            color: Theme.text-primary;
                            font-size: 13px;
                            overflow: elide;
                        }

                        ChipRow {
                            x: 32px;
                            y: parent.y-genres;
                            width: parent.cw;
                            height: parent.h-genres;
                            visible: root.detail-genres.length > 0;
                            chips: root.detail-genres;
                        }

                        Text {
                            x: 32px;
                            y: parent.y-cast-label;
                            width: parent.cw;
                            visible: root.detail-cast.length > 0;
                            text: "Reparto";
                            color: Theme.text-primary;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        CastStrip {
                            x: 32px;
                            y: parent.y-cast;
                            width: parent.cw;
                            height: parent.h-cast;
                            visible: root.detail-cast.length > 0;
                            cast: root.detail-cast;
                        }

                        Text {
                            x: 32px;
                            y: parent.y-facts;
                            width: parent.cw;
                            visible: root.detail-premiere != "";
                            text: root.detail-premiere;
                            color: Theme.text-muted;
                            font-size: 12px;
                        }
                        Text {
                            x: 32px;
                            y: parent.y-facts + parent.h-premiere;
                            width: parent.cw;
                            visible: root.detail-country != "";
                            text: root.detail-country;
                            color: Theme.text-muted;
                            font-size: 12px;
                        }
                        Text {
                            x: 32px;
                            y: parent.y-facts + parent.h-premiere + parent.h-country;
                            width: parent.cw;
                            visible: root.detail-studios != "";
                            text: root.detail-studios;
                            color: Theme.text-muted;
                            font-size: 12px;
                            overflow: elide;
                        }

                        ChipRow {
                            x: 32px;
                            y: parent.y-tags;
                            width: parent.cw;
                            height: parent.h-tags;
                            visible: root.detail-tags.length > 0;
                            chips: root.detail-tags;
                        }

                        Text {
                            x: 32px;
                            y: parent.y-media-label;
                            width: parent.cw;
                            visible: root.detail-media-info.length > 0;
                            text: "Información del medio";
                            color: Theme.text-primary;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        ChipRow {
                            x: 32px;
                            y: parent.y-media;
                            width: parent.cw;
                            height: parent.h-media;
                            visible: root.detail-media-info.length > 0;
                            chips: root.detail-media-info;
                        }

                        imdb-link := LinkPill {
                            x: 32px;
                            y: parent.y-links;
                            width: 92px;
                            height: 28px;
                            visible: root.detail-imdb-url != "";
                            label: "↗  IMDb";
                            clicked => { root.open-url(root.detail-imdb-url); }
                        }
                        LinkPill {
                            x: root.detail-imdb-url != "" ? 136px : 32px;
                            y: parent.y-links;
                            width: 92px;
                            height: 28px;
                            visible: root.detail-tmdb-url != "";
                            label: "↗  TMDB";
                            clicked => { root.open-url(root.detail-tmdb-url); }
                        }

                        // Series children (seasons / episodes).
                        Text {
                            x: 32px;
                            y: parent.y-children-label;
                            width: parent.cw;
                            visible: root.detail-children-label != "";
                            text: root.detail-children-label;
                            color: Theme.text-primary;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        Rectangle {
                            x: 32px;
                            y: parent.y-children;
                            width: parent.cw;
                            height: parent.h-children;
                            visible: root.items.length > 0;
                            for it[i] in root.items: Card {
                                x: mod(i, detail.grid-cols) * (180px + 20px);
                                y: floor(i / max(1, detail.grid-cols)) * (250px + 20px);
                                data: it;
                                clicked => {
                                    root.activate-item(it.id, it.item-type);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// --- settings ------------------------------------------------------

component SettingsTab inherits TouchArea {
    in property <string> label;
    in property <string> icon;
    in property <bool> active;
    in property <bool> enabled-tab: true;
    width: 96px;
    height: 60px;
    mouse-cursor: root.enabled-tab ? pointer : default;

    Rectangle {
        background: root.active
            ? #ffffff0c
            : (root.has-hover && root.enabled-tab ? #ffffff06 : transparent);
        border-radius: 10px;
        animate background { duration: 120ms; }

        VerticalLayout {
            spacing: 4px;
            padding: 8px;
            alignment: center;
            Text {
                text: root.icon;
                color: root.active ? Theme.accent : Theme.text-muted;
                font-size: 20px;
                horizontal-alignment: center;
            }
            Text {
                text: root.label;
                color: root.active ? Theme.accent : Theme.text-muted;
                font-size: 11px;
                font-weight: 500;
                horizontal-alignment: center;
            }
        }
    }
}

component ToggleSwitch inherits TouchArea {
    in-out property <bool> value;
    callback toggled(bool);
    width: 44px;
    height: 26px;
    mouse-cursor: pointer;
    clicked => {
        root.value = !root.value;
        root.toggled(root.value);
    }

    Rectangle {
        background: root.value ? Theme.accent : #3a3f4a;
        border-radius: 13px;
        animate background { duration: 150ms; easing: ease-out; }

        Rectangle {
            x: root.value ? parent.width - self.width - 3px : 3px;
            y: (parent.height - self.height) / 2;
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: white;
            drop-shadow-color: #00000040;
            drop-shadow-blur: 4px;
            drop-shadow-offset-y: 1px;
            animate x { duration: 150ms; easing: ease-out; }
        }
    }
}

component DeviceDropdown inherits Rectangle {
    in property <[AudioDeviceItem]> devices;
    in property <string> selected-id;
    // Resolved display name — backend pushes this when selection or
    // device list changes, so we don't have to do lookups in Slint
    // (whose expression language has no looped find-by-key form).
    in property <string> selected-label;
    callback select(string);

    property <bool> open: false;

    height: 32px;
    width: 260px;

    Rectangle {
        background: #1a1d24;
        border-radius: 8px;
        border-width: 1px;
        border-color: trigger.has-hover ? #ffffff20 : Theme.stroke-faint;
        animate border-color { duration: 120ms; }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 10px;
            spacing: 8px;
            Text {
                text: root.selected-label;
                color: Theme.text-primary;
                font-size: 13px;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            Text {
                text: "▾";
                color: Theme.text-muted;
                font-size: 14px;
                vertical-alignment: center;
            }
        }

        trigger := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.open = !root.open; }
        }
    }

    // Popup menu — absolutely positioned below the trigger, on top of
    // surrounding content via z-order (declared after the trigger).
    Rectangle {
        x: 0;
        y: 36px;
        width: max(parent.width, 340px);
        height: min(320px, (root.devices.length + 1) * 40px + 8px);
        background: #14161b;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.stroke-faint;
        drop-shadow-color: #00000099;
        drop-shadow-blur: 24px;
        drop-shadow-offset-y: 8px;
        visible: root.open;

        Flickable {
            x: 4px;
            y: 4px;
            width: parent.width - 8px;
            height: parent.height - 8px;
            viewport-width: self.width;
            viewport-height: (root.devices.length + 1) * 40px;

            // System default row.
            default-row := TouchArea {
                x: 0;
                y: 0;
                width: parent.width;
                height: 40px;
                mouse-cursor: pointer;
                clicked => {
                    root.select("");
                    root.open = false;
                }
                Rectangle {
                    background: parent.has-hover ? #ffffff10 : transparent;
                    border-radius: 6px;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        Text {
                            text: root.selected-id == "" ? "✓" : "";
                            color: Theme.accent;
                            width: 14px;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: "System default";
                            color: Theme.text-primary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            for d[i] in root.devices: TouchArea {
                x: 0;
                y: 40px + i * 40px;
                width: parent.width;
                height: 40px;
                mouse-cursor: pointer;
                clicked => {
                    root.select(d.id);
                    root.open = false;
                }
                Rectangle {
                    background: parent.has-hover ? #ffffff10 : transparent;
                    border-radius: 6px;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        Text {
                            text: d.id == root.selected-id ? "✓" : "";
                            color: Theme.accent;
                            width: 14px;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            Text {
                                text: d.description;
                                color: Theme.text-primary;
                                font-size: 13px;
                                vertical-alignment: bottom;
                                overflow: elide;
                            }
                            Text {
                                text: d.id;
                                color: Theme.text-muted;
                                font-size: 10px;
                                vertical-alignment: top;
                                overflow: elide;
                            }
                        }
                        Rectangle {
                            width: d.bitperfect ? 64px : 48px;
                            height: 18px;
                            y: (parent.height - self.height) / 2;
                            background: d.bitperfect ? #4caf5022 : #ffffff10;
                            border-radius: 9px;
                            border-width: 1px;
                            border-color: d.bitperfect ? #4caf5099 : Theme.stroke-faint;
                            Text {
                                text: d.bitperfect ? "Bitperfect" : "Mixer";
                                color: d.bitperfect ? #8fdc92 : Theme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}

component SettingsScreen inherits Rectangle {
    in property <[AudioDeviceItem]> audio-devices;
    in property <string> selected-audio-device;
    in property <string> selected-audio-device-label;
    in-out property <bool> exclusive-mode;
    in property <bool> devices-loading;
    callback close();
    callback select-audio-device(string);
    callback set-exclusive-mode(bool);
    callback refresh-devices();

    background: Theme.bg-base;

    // Header with title + close.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 56px;
        background: Theme.bg-base;

        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: "Settings";
            color: Theme.text-primary;
            font-size: 15px;
            font-weight: 600;
        }
        done-btn := TouchArea {
            x: parent.width - self.width - 20px;
            y: (parent.height - self.height) / 2;
            width: 64px;
            height: 30px;
            mouse-cursor: pointer;
            clicked => { root.close(); }
            Rectangle {
                background: parent.has-hover ? Theme.accent-hover : Theme.accent;
                border-radius: 15px;
                animate background { duration: 120ms; }
                Text {
                    text: "Done";
                    color: white;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // Tab strip — Audio is the only section today. Last.fm / Jellystat
    // / Discogs tabs will be added back when those integrations land.
    Rectangle {
        x: 0;
        y: 56px;
        width: parent.width;
        height: 80px;
        HorizontalLayout {
            x: (parent.width - self.width) / 2;
            spacing: 6px;
            y: 8px;
            SettingsTab { label: "Audio"; icon: "🔊"; active: true; }
        }
    }

    // Audio panel.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 152px;
        width: min(720px, parent.width - 80px);
        height: parent.height - 180px;
        background: Theme.bg-base;

        VerticalLayout {
            spacing: 24px;

            // Exclusive mode card.
            Rectangle {
                height: 110px;
                background: Theme.bg-panel;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.stroke-faint;

                VerticalLayout {
                    padding: 18px;
                    spacing: 6px;

                    HorizontalLayout {
                        spacing: 12px;
                        Text {
                            text: "Exclusive (bit-perfect) mode";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        ToggleSwitch {
                            value <=> root.exclusive-mode;
                            toggled(v) => { root.set-exclusive-mode(v); }
                        }
                    }
                    Text {
                        text: "Music takes exclusive control of the output device, matches the device's sample rate to the file, and bypasses the system mixer for bit-perfect playback.";
                        color: Theme.text-muted;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }

            // Output device card.
            Rectangle {
                height: 140px;
                background: Theme.bg-panel;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.stroke-faint;

                VerticalLayout {
                    padding: 18px;
                    spacing: 14px;

                    Text {
                        text: "Output device";
                        color: Theme.text-primary;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        Text {
                            text: "Device";
                            color: Theme.text-primary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        DeviceDropdown {
                            devices: root.audio-devices;
                            selected-id: root.selected-audio-device;
                            selected-label: root.selected-audio-device-label;
                            select(id) => { root.select-audio-device(id); }
                        }
                    }

                    HorizontalLayout {
                        Rectangle { horizontal-stretch: 1; }
                        refresh-btn := TouchArea {
                            width: 92px;
                            height: 30px;
                            mouse-cursor: pointer;
                            clicked => { root.refresh-devices(); }
                            Rectangle {
                                background: parent.has-hover ? #ffffff14 : #ffffff08;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: Theme.stroke-faint;
                                animate background { duration: 120ms; }
                                Text {
                                    text: root.devices-loading ? "Loading…" : "Refresh";
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}

// --- root window ---------------------------------------------------

export component MainWindow inherits Window {
    title: "jlfine";
    icon: @image-url("icon.png");
    preferred-width: 1100px;
    preferred-height: 720px;
    background: Theme.bg-base;

    in-out property <Screen> screen: Screen.login;
    in-out property <string> server-url: "";
    in-out property <string> username: "";
    in-out property <string> password: "";
    in property <string> error-message: "";
    in property <bool> busy: false;
    in property <string> user-name: "";
    in property <[ViewItem]> views: [];
    in-out property <int> selected-view: 0;
    in property <[Item]> items: [];
    in property <bool> loading: false;
    in property <string> view-title: "";
    in property <string> view-subtitle: "";
    in property <string> view-collection-type: "";
    in property <string> view-mode: "grid";
    in property <bool> can-go-back: false;
    in property <image> album-image;
    in property <bool> album-has-image: false;
    in property <string> album-artist: "";
    in property <string> album-meta: "";
    in property <[string]> album-genres: [];
    in property <string> album-overview: "";
    in property <string> album-wikipedia-url: "";
    in property <string> album-download-label: "⬇  Descargar álbum";
    in property <bool> album-download-enabled: true;
    in property <bool> album-download-active: false;
    in property <image> detail-backdrop;
    in property <bool> detail-has-backdrop: false;
    in property <string> detail-meta: "";
    in property <string> detail-tagline: "";
    in property <string> detail-overview: "";
    in property <string> detail-director: "";
    in property <string> detail-writers: "";
    in property <[string]> detail-genres: [];
    in property <[CastMember]> detail-cast: [];
    in property <string> detail-premiere: "";
    in property <string> detail-country: "";
    in property <string> detail-studios: "";
    in property <[string]> detail-tags: [];
    in property <[string]> detail-media-info: [];
    in property <string> detail-imdb-url: "";
    in property <string> detail-tmdb-url: "";
    in property <bool> detail-can-play: false;
    in property <string> detail-children-label: "";
    in property <[AudioDeviceItem]> audio-devices: [];
    in property <string> selected-audio-device: "";
    in property <string> selected-audio-device-label: "System default";
    in-out property <bool> exclusive-mode: true;
    in property <bool> devices-loading: false;

    callback sign-in-clicked(string, string, string);
    callback sign-out-clicked();
    callback view-selected(string, string);
    callback activate-item(string, string);
    callback back-clicked();
    callback open-settings();
    callback select-audio-device(string);
    callback set-exclusive-mode(bool);
    callback refresh-devices();
    callback open-url(string);
    callback download-album();
    callback play-detail();
    callback download-detail();

    // Two screens; cross-fade between them with opacity.
    login := LoginScreen {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        opacity: root.screen == Screen.login ? 1.0 : 0.0;
        visible: self.opacity > 0.001;
        animate opacity { duration: 220ms; easing: ease-out; }

        server-url <=> root.server-url;
        username <=> root.username;
        password <=> root.password;
        error-message: root.error-message;
        busy: root.busy;
        submit => { root.sign-in-clicked(root.server-url, root.username, root.password); }
    }

    library := LibraryScreen {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        opacity: root.screen == Screen.library ? 1.0 : 0.0;
        visible: self.opacity > 0.001;
        animate opacity { duration: 220ms; easing: ease-out; }

        views: root.views;
        user-name: root.user-name;
        selected-index: root.selected-view;
        items: root.items;
        loading: root.loading;
        view-title: root.view-title;
        view-subtitle: root.view-subtitle;
        view-collection-type: root.view-collection-type;
        view-mode: root.view-mode;
        can-go-back: root.can-go-back;
        album-image: root.album-image;
        album-has-image: root.album-has-image;
        album-artist: root.album-artist;
        album-meta: root.album-meta;
        album-genres: root.album-genres;
        album-overview: root.album-overview;
        album-wikipedia-url: root.album-wikipedia-url;
        album-download-label: root.album-download-label;
        album-download-enabled: root.album-download-enabled;
        album-download-active: root.album-download-active;
        detail-backdrop: root.detail-backdrop;
        detail-has-backdrop: root.detail-has-backdrop;
        detail-meta: root.detail-meta;
        detail-tagline: root.detail-tagline;
        detail-overview: root.detail-overview;
        detail-director: root.detail-director;
        detail-writers: root.detail-writers;
        detail-genres: root.detail-genres;
        detail-cast: root.detail-cast;
        detail-premiere: root.detail-premiere;
        detail-country: root.detail-country;
        detail-studios: root.detail-studios;
        detail-tags: root.detail-tags;
        detail-media-info: root.detail-media-info;
        detail-imdb-url: root.detail-imdb-url;
        detail-tmdb-url: root.detail-tmdb-url;
        detail-can-play: root.detail-can-play;
        detail-children-label: root.detail-children-label;
        open-url(u) => { root.open-url(u); }
        download-album => { root.download-album(); }
        play-detail => { root.play-detail(); }
        download-detail => { root.download-detail(); }
        select-view(i, id, ct) => {
            root.selected-view = i;
            root.view-selected(id, ct);
        }
        sign-out => { root.sign-out-clicked(); }
        activate-item(id, ct) => { root.activate-item(id, ct); }
        back-clicked => { root.back-clicked(); }
        open-settings => { root.open-settings(); }
    }

    settings-screen := SettingsScreen {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        opacity: root.screen == Screen.settings ? 1.0 : 0.0;
        visible: self.opacity > 0.001;
        animate opacity { duration: 220ms; easing: ease-out; }

        audio-devices: root.audio-devices;
        selected-audio-device: root.selected-audio-device;
        selected-audio-device-label: root.selected-audio-device-label;
        exclusive-mode <=> root.exclusive-mode;
        devices-loading: root.devices-loading;
        close => { root.screen = Screen.library; }
        select-audio-device(id) => { root.select-audio-device(id); }
        set-exclusive-mode(v) => { root.set-exclusive-mode(v); }
        refresh-devices => { root.refresh-devices(); }
    }
}
